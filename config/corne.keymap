#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/modifiers.h>
#include "ch-de.h"


#define BASE           0
#define I3             1
#define SYS            2
#define SYMBL          3
#define NUM            4
#define FUNC           5


/* Key position groups used by hold-trigger-key-positions
 * in the BT hold-taps (n1_btclr, ht_bt) and ht behavior.
 * LEFT_HAND_KEYS is kept for symmetry / future use. */
#define LEFT_HAND_KEYS \
        0 1 2 3 4 5 12 13 14 15 16 17 24 25 26 27 28 29
#define RIGHT_HAND_KEYS \
        6 7 8 9 10 11 18 19 20 21 22 23 30 31 32 33 34 35
#define THUMB_KEYS \
        36 37 38 39 40 41

/ {
 
        macros {
                /* ── sys_fnc ───────────────────────────────────────────────
                 *  Hold → activate SYS (system) layer
                 *  Release → turn off FUNC layer if it was toggled on
                 *  Activation: right thumb middle key (BASE layer, pos 40)
                 * ─────────────────────────────────────────────────────────── */
                sys_fnc: mod_tap_function_layer {
                        compatible = "zmk,behavior-macro";
                        #binding-cells = <0>;
                        wait-ms = <0>;
                        tap-ms = <0>;
                        bindings = <&macro_press &mo SYS>, <&macro_pause_for_release>, <&macro_tap &toff FUNC>, <&macro_release &mo SYS>;
                };

                /* ── nav_num ───────────────────────────────────────────────
                 *  Hold → activate I3 (navigation) layer
                 *  Release → turn off NUM layer if it was toggled on
                 *  Activation: left thumb middle key (BASE layer, pos 37)
                 * ─────────────────────────────────────────────────────────── */
                nav_num: mod_tap_number_layer {
                        compatible = "zmk,behavior-macro";
                        #binding-cells = <0>;
                        wait-ms = <0>;
                        tap-ms = <0>;
                        bindings = <&macro_press &mo I3>, <&macro_pause_for_release>, <&macro_tap &toff NUM>, <&macro_release &mo I3>;
                };

                /* ── arrow_fn ──────────────────────────────────────────────
                 *  Types: = () => { \n  (JS/TS arrow function skeleton)
                 *  Editor auto-indent places cursor inside the braces
                 *  Activation: press ( and ) simultaneously on SYMBL layer
                 *              (combo on positions 25+26, 50ms window)
                 * ─────────────────────────────────────────────────────────── */
                arrow_fn: arrow_function {
                        compatible = "zmk,behavior-macro";
                        #binding-cells = <0>;
                        wait-ms = <30>;
                        tap-ms = <30>;
                        bindings = <&kp DE_EQUAL &kp SPACE
                                    &kp DE_LPAR &kp DE_RPAR &kp SPACE
                                    &kp DE_EQUAL &kp DE_GT &kp SPACE
                                    &kp DE_LBRC &kp SPACE &kp RET>;
                };

                /* ── kp_once ───────────────────────────────────────────────
                 *  Parameterised helper: taps a single keycode passed as
                 *  its argument. Used as the hold binding in the &ht
                 *  hold-tap behavior so that hold produces a keypress
                 *  rather than a modifier.
                 * ─────────────────────────────────────────────────────────── */
                kp_once: key_press_once {
                        compatible = "zmk,behavior-macro-one-param";
                        #binding-cells = <1>;
                        wait-ms = <0>;
                        tap-ms = <0>;
                        bindings = <&macro_param_1to1 &kp MACRO_PLACEHOLDER>;
                };
        };
        behaviors {
                /* Layer Toggler */
                ton: toggle_layer_on{
                        compatible = "zmk,behavior-toggle-layer";
                        #binding-cells = <1>;
                        toggle-mode = "on";
                };
                toff: toggle_layer_off {
                        compatible = "zmk,behavior-toggle-layer";
                        #binding-cells = <1>;
                        toggle-mode = "off";
                };


                /* ── bt_clr_macro / n1_btclr ───────────────────────────────
                 *  bt_clr_macro: helper that sends BT_CLR
                 *  n1_btclr: hold-tap wrapping bt_clr_macro
                 *    Tap  → keypress (e.g. TAB)
                 *    Hold → clear current BT profile
                 *  Activation: SYS layer, top-left key (pos 0)
                 * ─────────────────────────────────────────────────────────── */
                bt_clr_macro: bt_clr_macro {
                        compatible = "zmk,behavior-macro";
                        #binding-cells = <0>;
                        bindings = <&bt BT_CLR>;
                };
                n1_btclr: n1_btclr {
                        compatible = "zmk,behavior-hold-tap";
                        #binding-cells = <2>;
                        flavor = "balanced";
                        tapping-term-ms = <280>;
                        quick-tap-ms = <175>;
                        require-prior-idle-ms = <150>;
                        bindings = <&bt_clr_macro>, <&kp>;
                        hold-trigger-key-positions = <RIGHT_HAND_KEYS THUMB_KEYS>;
                        hold-trigger-on-release;
                };

                /* ── bt_sel / ht_bt ────────────────────────────────────────
                 *  bt_sel: one-param macro that selects a BT profile
                 *  ht_bt: hold-tap wrapping bt_sel
                 *    Tap  → keypress (e.g. DE_N1 through DE_N5)
                 *    Hold → select the BT profile passed as 1st param
                 *  Activation: SYS layer, top row keys 1-5 (pos 1-5)
                 * ─────────────────────────────────────────────────────────── */
                bt_sel: bt_select {
                        compatible = "zmk,behavior-macro-one-param";
                        #binding-cells = <1>;
                        bindings = <&macro_param_1to2 &bt BT_SEL MACRO_PLACEHOLDER>;
                };
                ht_bt: hold_tap_bt {
                        compatible = "zmk,behavior-hold-tap";
                        #binding-cells = <2>;
                        flavor = "balanced";
                        tapping-term-ms = <280>;
                        quick-tap-ms = <175>;
                        require-prior-idle-ms = <150>;
                        bindings = <&bt_sel>, <&kp>;
                        hold-trigger-key-positions = <RIGHT_HAND_KEYS THUMB_KEYS>;
                        hold-trigger-on-release;
                };
                ht: hold_tap {
                        compatible = "zmk,behavior-hold-tap";
                        #binding-cells = <2>;
                        flavor = "balanced";
                        tapping-term-ms = <280>;
                        quick-tap-ms = <175>;
                        require-prior-idle-ms = <150>;
                        bindings = <&kp_once>, <&kp>;
                        hold-trigger-key-positions = <RIGHT_HAND_KEYS THUMB_KEYS>;
                        hold-trigger-on-release;
                };
        };


        combos {
                compatible = "zmk,combos";
                /* Press ( + ) at the same time on SYMBL layer → arrow_fn macro */
                combo_arrow_fn {
                        timeout-ms = <50>;
                        key-positions = <25 26>;
                        bindings = <&arrow_fn>;
                        layers = <SYMBL>;
                };
        };

        keymap {
                compatible = "zmk,keymap";

                base_layer {
                        display-name = "BASE";
                                                                                                                               // XXX //                                       
                        bindings = <                 
        &ht ESC TAB          &ht DE_PIPE DE_Q   &kp DE_W         &kp DE_E               &kp DE_R          &kp DE_T                            &kp DE_Z         &kp DE_U              &kp DE_I               &kp DE_O          &ht DE_TILDE DE_P   &kp DEL
        &kp LSHFT            &kp DE_A           &kp DE_S         &kp DE_D               &kp DE_F          &kp DE_G                            &kp DE_H         &kp DE_J              &kp DE_K               &kp DE_L          &kp DE_UMLAUT       &kp LALT
        &kp LCTRL            &kp DE_Y           &kp DE_X         &kp DE_C               &kp DE_V          &kp DE_B                            &kp DE_N         &kp DE_M              &kp DE_COMMA           &kp DE_DOT        &kp DE_MINUS        &kp RET
                                                                 &kp LGUI               &nav_num          &kp SPACE                           &kp BACKSPACE    &sys_fnc              &mo SYMBL
                        >;                 
                };                 
                 
                i3_layer {                 
                        display-name = "I3";                 
                        bindings = <                 
        &kp ESC              &kp LG(N1)         &kp LG(N2)       &kp LG(N3)             &kp LG(N4)        &kp LG(N5)                          &kp LG(N6)       &kp LG(N7)            &kp LG(N8)             &kp LG(N9)        &kp LG(N0)          &trans
        &kp LSHFT            &kp LG(LC(A))      &none            &kp LG(LC(S))          &none             &kp LG(DE_MINUS)                    &kp DE_PLUS      &kp DE_EQUAL          &kp LG(UP)             &none             &none               &trans
        &kp LCTRL            &kp LG(DE_Y)       &none            &none                  &kp LG(E)         &kp LG(V)                           &kp DE_MINUS     &kp LG(LEFT)          &kp LG(DOWN)           &kp LG(RIGHT)     &none               &trans
                                                                 &ton NUM               &none             &kp LG(SPACE)                       &kp BACKSPACE    &none                 &none
                        >;                 
                };                 
                 
                 
                system_layer {
                        display-name = "SYSTEM";
                        bindings = <
        &n1_btclr 0 TAB      &ht_bt 0 DE_N1     &ht_bt 1 DE_N2   &ht_bt 2 DE_N3         &ht_bt 3 DE_N4    &ht_bt 4 DE_N5                      &kp DE_N6        &kp DE_N7             &kp DE_N8              &kp DE_N9         &kp DE_N0           &trans                
        &kp LSHFT            &kp DE_LBRC        &kp DE_RBRC      &none                  &kp DE_LPAR       &kp DE_RPAR                         &kp DE_PLUS      &kp HOME              &kp UP                 &kp END           &kp DE_SQT          &trans                
        &kp LCTRL            &kp DE_LBKT        &kp DE_RBKT      &kp DE_EQUAL           &kp DE_GT         &kp DE_COMMA                        &kp DE_MINUS     &kp LEFT              &kp DOWN               &kp RIGHT         &kp DE_DQT          &trans                
                                                                 &none                  &none             &kp SPACE                           &kp BACKSPACE    &none                 &ton FUNC
                        >;
                };


                symbol_layer {                 
                        display-name = "SYMBOL";                   
                        bindings = <                 
        &kp ESC              &kp DE_EXCL        &kp DE_AT        &kp DE_HASH            &none             &kp DE_ACUTE                       &kp DE_CARET       &kp DE_DLLR          &kp DE_PRCNT           &kp DE_QMARK      &kp DE_SQT          &kp DEL
        &kp LSHFT            &trans             &trans           &trans                 &trans            &trans                             &none              &none                &none                  &kp DE_PIPE       &kp DE_DQT          &kp LALT
        &kp LCTRL            &trans             &trans           &trans                 &trans            &trans                             &none              &none                &kp DE_COMMA           &kp DE_FSLH       &kp DE_BSLH         &kp RET
                                                                 &none                  &none             &kp SPACE                          &kp BACKSPACE      &none                &none
                        >;
                };

                number_layer {                 
                        display-name = "NUMBER";                 
                        bindings = <                 
        &kp ESC             &none              &none            &none                   &none             &none                               &none            &kp DE_FSLH           &kp DE_N7              &kp DE_N8         &kp DE_N9           &kp DEL
        &kp LSHFT           &none              &none            &none                   &none             &none                               &none            &kp DE_MINUS          &kp DE_N4              &kp DE_N5         &kp DE_N6           &kp LALT
        &kp LCTRL           &none              &none            &none                   &none             &none                               &none            &kp DE_DOT            &kp DE_N1              &kp DE_N2         &kp DE_N3           &kp RET
                                                                &none                   &none             &kp SPACE                           &kp BACKSPACE    &none                 &kp DE_N0          
                        >;                 
                };                 
                 
                function_layer {                 
                        display-name = "FUNCTION";                 
                        bindings = <                 
        &kp ESC           &kp F2             &kp F3           &kp F4                    &kp F5            &kp F6                              &kp F7           &kp F8                &kp F9                 &kp F10           &kp F11             &kp F12
        &kp LSHFT         &none              &none            &none                     &none             &none                               &none            &none                 &none                  &none             &none               &kp LALT
        &kp LCTRL         &studio_unlock     &none            &none                     &none             &none                               &none            &none                 &none                  &none             &none               &kp RET          
                                                              &none                     &none             &kp SPACE                           &kp BACKSPACE    &none                 &none                  
                                                                                         >;
                };


                
                       };



};
